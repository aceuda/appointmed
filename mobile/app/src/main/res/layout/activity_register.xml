<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Top bar with back arrow and AppointMed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/imageRegisterBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="@color/textPrimary"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="AppointMed"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:gravity="center" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp" />
        </LinearLayout>

        <!-- Brand Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appoint"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Med"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#38BDF8" />
        </LinearLayout>

        <!-- Heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join the AppointMed medical portal\nand manage your health."
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <!-- Role Tab Selector: Patient | Doctor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_container"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/buttonRolePatient"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:background="@drawable/bg_tab_active"
                android:text="Patient"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:stateListAnimator="@null"
                android:elevation="1dp" />

            <Button
                android:id="@+id/buttonRoleDoctor"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="42dp"
                android:background="@drawable/bg_tab_inactive"
                android:text="Doctor"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Error Message -->
        <TextView
            android:id="@+id/textRegisterError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <!-- Success Message -->
        <TextView
            android:id="@+id/textRegisterMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/success"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <!-- Full Name Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Full Name Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Name icon" />

            <EditText
                android:id="@+id/inputFullName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="John Doe"
                android:textColorHint="#CBD5E1"
                android:inputType="textPersonName"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />
        </LinearLayout>

        <!-- Email Address Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Email Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Email icon" />

            <EditText
                android:id="@+id/inputEmailRegister"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="name@clinic.com"
                android:textColorHint="#CBD5E1"
                android:inputType="textEmailAddress"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />
        </LinearLayout>

        <!-- Phone Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Phone Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Phone icon" />

            <EditText
                android:id="@+id/inputPhone"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="+1 (555) 123-4567"
                android:textColorHint="#CBD5E1"
                android:inputType="phone"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />
        </LinearLayout>

        <!-- Address Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Address Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Address icon" />

            <EditText
                android:id="@+id/inputAddress"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="123 Main St, City"
                android:textColorHint="#CBD5E1"
                android:inputType="textPostalAddress"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />
        </LinearLayout>

        <!-- Patient-specific fields -->
        <LinearLayout
            android:id="@+id/patientFieldsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp">

            <!-- Gender & Birth Date row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:baselineAligned="false">

                <!-- Gender -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gender"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_auth"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Spinner
                            android:id="@+id/spinnerGender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/gender_options"
                            android:prompt="@string/prompt_gender"
                            android:background="@android:color/transparent"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Birth Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Birth Date"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_auth"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@android:drawable/ic_menu_today"
                            android:tint="#94A3B8"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Date icon" />

                        <EditText
                            android:id="@+id/inputBirthDate"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:hint="YYYY-MM-DD"
                            android:textColorHint="#CBD5E1"
                            android:inputType="date"
                            android:background="@android:color/transparent"
                            android:textSize="14sp"
                            android:textColor="@color/textPrimary"
                            android:minHeight="24dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Doctor-specific fields -->
        <LinearLayout
            android:id="@+id/doctorFieldsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <!-- Specialization Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Specialization"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_auth"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:tint="#94A3B8"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Specialization icon" />

                <EditText
                    android:id="@+id/inputSpecialization"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Cardiology"
                    android:textColorHint="#CBD5E1"
                    android:inputType="text"
                    android:background="@android:color/transparent"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:minHeight="24dp" />
            </LinearLayout>

            <!-- License Number Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="License Number"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_auth"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#94A3B8"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="License icon" />

                <EditText
                    android:id="@+id/inputLicenseNumber"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="LIC-XXXXX"
                    android:textColorHint="#CBD5E1"
                    android:inputType="text"
                    android:background="@android:color/transparent"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:minHeight="24dp" />
            </LinearLayout>

            <!-- Clinic Address Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clinic Address"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_auth"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="#94A3B8"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Clinic address icon" />

                <EditText
                    android:id="@+id/inputClinicAddress"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="Clinic location"
                    android:textColorHint="#CBD5E1"
                    android:inputType="textPostalAddress"
                    android:background="@android:color/transparent"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:minHeight="24dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Password Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Lock icon" />

            <EditText
                android:id="@+id/inputPasswordRegister"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:textColorHint="#CBD5E1"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#94A3B8"
                android:contentDescription="Toggle password visibility" />
        </LinearLayout>

        <!-- Confirm Password Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Confirm Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_auth"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:tint="#94A3B8"
                android:layout_marginEnd="12dp"
                android:contentDescription="Lock icon" />

            <EditText
                android:id="@+id/inputConfirmPassword"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:textColorHint="#CBD5E1"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:minHeight="24dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#94A3B8"
                android:contentDescription="Toggle password visibility" />
        </LinearLayout>

        <!-- Terms Checkbox -->
        <CheckBox
            android:id="@+id/checkboxTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="I agree to the Terms and Privacy Policy"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:buttonTint="#3B82F6" />

        <!-- Create Account Button -->
        <Button
            android:id="@+id/buttonRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_dark"
            android:text="Create Account →"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBarRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?  "
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/buttonGoLogin"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in"
                android:textAllCaps="false"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="0dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
