<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/cardBackground"
    android:padding="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical"
    android:elevation="1dp">

    <!-- Avatar -->
    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:background="@drawable/bg_avatar_circle"
        android:padding="10dp"
        android:layout_marginEnd="14dp"
        android:contentDescription="User" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/textAdminUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dr. Sarah Smith"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary" />
            <TextView
                android:id="@+id/textAdminUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/success" />
        </LinearLayout>
        <TextView
            android:id="@+id/textAdminUserDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cardiologist • MD"
            android:textSize="13sp"
            android:textColor="@color/textSecondary" />
        <TextView
            android:id="@+id/textAdminUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sarah.smith@med.com"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="6dp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Chevron -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textSize="24sp"
        android:textColor="@color/textSecondary"
        android:layout_marginStart="8dp" />
</LinearLayout>
