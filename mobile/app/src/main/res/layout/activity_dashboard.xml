<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView
        android:id="@+id/dashboardScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Top Bar: Avatar + Brand + Search & Bell -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_doctor_avatar" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"
                        android:contentDescription="User avatar" />
                </FrameLayout>

                <!-- Brand -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appoint"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Med"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#38BDF8" />
                </LinearLayout>

                <!-- Search -->
                <ImageButton
                    android:id="@+id/buttonSearch"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_icon_circle"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:contentDescription="Search"
                    android:tint="#64748B"
                    android:scaleType="centerInside" />

                <!-- Notifications -->
                <ImageButton
                    android:id="@+id/buttonNotifications"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_icon_circle"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:contentDescription="Notifications"
                    android:tint="#64748B"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <!-- Appointment Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_appointment_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Medical case icon placeholder -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#F8FAFC" />

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_add"
                        android:tint="#CBD5E1"
                        android:contentDescription="Medical icon" />
                </FrameLayout>

                <!-- UPCOMING badge + ID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="UPCOMING"
                        android:textAllCaps="true"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID: #AM-9283"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Doctor Name -->
                <TextView
                    android:id="@+id/textDoctorName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dr. Sarah Jenkins"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <!-- Date/time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_today"
                        android:tint="#94A3B8"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="Calendar" />

                    <TextView
                        android:id="@+id/textAppointmentDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tomorrow, Oct 24 • 10:00 AM"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>

                <!-- View Details + Delete row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/buttonViewDetails"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button_dark"
                        android:text="View Details"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null" />

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_icon_circle">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_delete"
                            android:tint="#94A3B8"
                            android:contentDescription="Delete" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Quick Actions Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Quick Actions Tiles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Quick Book -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_quick_action"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:tint="#3B82F6"
                            android:contentDescription="Quick Book" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Book"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Health Records -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_quick_action"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center"
                    android:layout_marginStart="8dp">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:tint="#3B82F6"
                            android:contentDescription="Health Records" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health Records"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Available Doctors Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Available Doctors"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All"
                    android:textColor="#3B82F6"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Doctor 1: Michael Chen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_doctor_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_doctor_avatar" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"
                        android:contentDescription="Doctor avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Michael Chen"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cardiologist • 12 yrs exp."
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="#16A34A"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.9"
                            android:textColor="#16A34A"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (120 reviews)"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_plus_circle">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary" />
                </FrameLayout>
            </LinearLayout>

            <!-- Doctor 2: Elena Rodriguez -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_doctor_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_doctor_avatar" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"
                        android:contentDescription="Doctor avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Elena Rodriguez"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dermatologist • 8 yrs exp."
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="#16A34A"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.8"
                            android:textColor="#16A34A"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (85 reviews)"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_plus_circle">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary" />
                </FrameLayout>
            </LinearLayout>

            <!-- Doctor 3: James Wilson -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_doctor_card"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_doctor_avatar" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"
                        android:contentDescription="Doctor avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. James Wilson"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Neurologist • 15 yrs exp."
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★"
                            android:textColor="#16A34A"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 5.0"
                            android:textColor="#16A34A"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (210 reviews)"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_plus_circle">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="@color/textSecondary" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/cardBackground"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Home (active) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#3B82F6"
                android:contentDescription="Home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#3B82F6"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Schedule -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_month"
                android:tint="@color/textSecondary"
                android:contentDescription="Schedule" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Doctors (center FAB) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="4dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_fab_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_input_add"
                    android:tint="@android:color/white"
                    android:contentDescription="Doctors" />
            </FrameLayout>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/bottomNavProfile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imageProfileIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/textSecondary"
                android:contentDescription="Profile" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
