<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/cardBackground">
        <ImageView
            android:id="@+id/btnBackSpecialist"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            android:layout_centerVertical="true"
            android:contentDescription="Back" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="AppointMed"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/primary" />
    </RelativeLayout>

    <!-- Search Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/cardBackground">
        <EditText
            android:id="@+id/inputSearchDoctor"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Search by name or specialty"
            android:background="@drawable/bg_search_input"
            android:paddingStart="40dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:inputType="text"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:textColorHint="@color/textSecondary" />
    </FrameLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:background="@color/cardBackground">
        <LinearLayout
            android:id="@+id/filterChipsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/chipAll" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="wrap_content" android:layout_height="36dp" android:text="All" android:textSize="12sp" android:textAllCaps="false" android:background="@drawable/bg_chip_active" android:textColor="@android:color/white" android:layout_marginEnd="8dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:minWidth="0dp" android:minHeight="0dp" />
            <Button android:id="@+id/chipCardio" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Cardiologist" android:textSize="12sp" android:textAllCaps="false" android:background="@drawable/bg_chip_inactive" android:textColor="@color/textSecondary" android:layout_marginEnd="8dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:minWidth="0dp" android:minHeight="0dp" />
            <Button android:id="@+id/chipDerma" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Dermatologist" android:textSize="12sp" android:textAllCaps="false" android:background="@drawable/bg_chip_inactive" android:textColor="@color/textSecondary" android:layout_marginEnd="8dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:minWidth="0dp" android:minHeight="0dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Results Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Available Specialists"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary" />
        <TextView
            android:id="@+id/textResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24 RESULTS"
            android:textSize="11sp"
            android:textColor="@color/textSecondary" />
    </LinearLayout>

    <!-- Doctor List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDoctors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/cardBackground"
        android:elevation="8dp"
        android:gravity="center_vertical">
        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" android:contentDescription="Home" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="@color/textSecondary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navSchedule" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_my_calendar" android:contentDescription="Schedule" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Schedule" android:textSize="10sp" android:textColor="@color/textSecondary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navDoctors" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" android:contentDescription="Doctors" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Doctors" android:textSize="10sp" android:textColor="@color/secondary" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" android:contentDescription="Profile" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="@color/textSecondary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
