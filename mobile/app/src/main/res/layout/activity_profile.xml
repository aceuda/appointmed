<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Top Bar: Back Arrow + AppointMed + Edit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/imageProfileBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:tint="@color/textPrimary"
                    android:contentDescription="Back"
                    android:clickable="true"
                    android:focusable="true" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appoint"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Med"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#38BDF8" />
                </LinearLayout>

            </LinearLayout>

            <!-- Profile Avatar Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="24dp"
                android:paddingBottom="20dp">

                <!-- Avatar with camera badge -->
                <FrameLayout
                    android:id="@+id/avatarSelector"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <View
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_avatar_circle" />

                    <ImageView
                        android:id="@+id/imageProfileAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"
                        android:contentDescription="Avatar" />

                    <!-- Camera badge -->
                    <FrameLayout
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_camera_badge">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="@android:color/white"
                            android:contentDescription="Change photo" />
                    </FrameLayout>
                </FrameLayout>

                <EditText
                    android:id="@+id/inputProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:textAlignment="center"
                    android:hint="Your name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="14dp"
                    android:background="@null"
                    android:inputType="textPersonName"
                    android:padding="0dp"
                    android:textIsSelectable="true" />

                <EditText
                    android:id="@+id/inputProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:textAlignment="center"
                    android:hint="user@example.com"
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="8dp"
                    android:background="@null"
                    android:inputType="textEmailAddress"
                    android:padding="0dp"
                    android:textIsSelectable="true" />

                <!-- Patient ID -->
                <TextView
                    android:id="@+id/textProfilePatientId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient ID: #PM-88291"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F5F9"
                android:layout_marginHorizontal="20dp" />

            <!-- Personal Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_personal_details"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Phone Number -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_phone_label"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_call"
                        android:tint="@color/textSecondary"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Phone icon" />

                    <EditText
                        android:id="@+id/inputPhone"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="+1 (555) 123-4567"
                        android:textColorHint="#94A3B8"
                        android:inputType="phone"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:minHeight="24dp" />
                </LinearLayout>

                <!-- Home Address -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_address_label"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:tint="@color/textSecondary"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Address icon" />

                    <EditText
                        android:id="@+id/inputAddress"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="123 Medical Plaza, San Francisco, CA"
                        android:textColorHint="#94A3B8"
                        android:inputType="textPostalAddress"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:minHeight="24dp" />
                </LinearLayout>

                <!-- Date of Birth and Blood Type row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp"
                    android:baselineAligned="false">

                    <!-- Date of Birth -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_dob_label"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_menu_today"
                                android:tint="@color/textSecondary"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Date icon" />

                            <EditText
                                android:id="@+id/inputBirthDate"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:hint="05/14/1988"
                                android:textColorHint="#94A3B8"
                                android:inputType="date"
                                android:background="@android:color/transparent"
                                android:textSize="14sp"
                                android:textColor="@color/textPrimary"
                                android:minHeight="24dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blood Type -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_blood_type_label"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@android:drawable/ic_menu_compass"
                                android:tint="#EF4444"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Blood type icon" />

                            <Spinner
                                android:id="@+id/spinnerBloodType"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:entries="@array/blood_type_options"
                                android:background="@android:color/transparent"
                                android:spinnerMode="dropdown" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="32dp">

                <!-- Save Changes Button -->
                <Button
                    android:id="@+id/buttonSaveChanges"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_save_button"
                    android:text="💾  Save Changes"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />

                <!-- Discard Changes -->
                <Button
                    android:id="@+id/buttonDiscardChanges"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@android:color/transparent"
                    android:text="@string/button_discard_changes"
                    android:textAllCaps="false"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:stateListAnimator="@null" />

                <!-- Logout Button -->
                <Button
                    android:id="@+id/buttonLogout"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_logout_button"
                    android:text="@string/button_logout"
                    android:textAllCaps="false"
                    android:textColor="@color/error"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F1F5F9"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp" />

            <!-- Change Password Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CHANGE PASSWORD"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Password Error -->
                <TextView
                    android:id="@+id/textPasswordError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Password Success -->
                <TextView
                    android:id="@+id/textPasswordSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Current Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Current Password"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:tint="#94A3B8"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Lock icon" />

                    <EditText
                        android:id="@+id/inputCurrentPassword"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Enter current password"
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:minHeight="24dp" />
                </LinearLayout>

                <!-- New Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="New Password"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:tint="#94A3B8"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Lock icon" />

                    <EditText
                        android:id="@+id/inputNewPassword"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Enter new password"
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:minHeight="24dp" />
                </LinearLayout>

                <!-- Confirm New Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Confirm New Password"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:tint="#94A3B8"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Lock icon" />

                    <EditText
                        android:id="@+id/inputConfirmNewPassword"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Re-enter new password"
                        android:textColorHint="#94A3B8"
                        android:inputType="textPassword"
                        android:background="@android:color/transparent"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:minHeight="24dp" />
                </LinearLayout>

                <!-- Update Password Button -->
                <Button
                    android:id="@+id/buttonUpdatePassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_save_button"
                    android:text="🔒  Update Password"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />

                <!-- Password Progress -->
                <ProgressBar
                    android:id="@+id/progressBarPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/cardBackground"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@color/textSecondary"
                android:contentDescription="Home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="@color/textSecondary"
                android:contentDescription="Visits" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visits"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="@color/textSecondary"
                android:contentDescription="Records" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Records"
                android:textSize="11sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#3B82F6"
                android:contentDescription="Profile" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#3B82F6"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
